import json
import boto3
import urllib.parse
import os

# Clean, official entry-point imports from the Adobe SDK core specification
from adobe.pdfservices.operation.auth.service_principal_credentials import ServicePrincipalCredentials
from adobe.pdfservices.operation.pdf_services import PDFServices
from adobe.pdfservices.operation.pdf_services_media_type import PDFServicesMediaType

# Top-level job paths matching the precise SDK release specification
from adobe.pdfservices.operation.pdfjobs.jobs.create_pdf_job import CreatePDFJob
from adobe.pdfservices.operation.pdfjobs.result.create_pdf_result import CreatePDFResult

# Force the S3 client to communicate natively using your Frankfurt data region
REGION = "eu-central-1"
s3 = boto3.client("s3", region_name=REGION)
dynamodb = boto3.resource("dynamodb", region_name=REGION)

def lambda_handler(event, context):
    print("==== LAMBDA S3 TRIGGER START ====")
    print("Event Data:", json.dumps(event))
    
    if "ADOBE_CLIENT_ID" not in os.environ or "ADOBE_CLIENT_SECRET" not in os.environ:
        raise Exception("Missing ADOBE_CLIENT_ID or ADOBE_CLIENT_SECRET in Lambda Environment Variables.")

    for record in event["Records"]:
        bucket = record["s3"]["bucket"]["name"]
        key = urllib.parse.unquote_plus(record["s3"]["object"]["key"]).strip()

        if not key.startswith("uploads/"):
            print(f"Skipping key execution path outside uploads/: {key}")
            continue

        print(f"Targeting file for conversion: {key}")

        input_path = "/tmp/input.docx"
        output_path = "/tmp/output.pdf"

        # 1. Download source document from S3 landing zone safely
        s3.download_file(bucket, key, input_path)
        print("Downloaded file locally to /tmp.")

        try:
            # 2. Setup Adobe Credentials and Services client
            credentials = ServicePrincipalCredentials(
                client_id=os.environ["ADOBE_CLIENT_ID"],
                client_secret=os.environ["ADOBE_CLIENT_SECRET"]
            )
            pdf_services = PDFServices(credentials=credentials)

            # 3. Read the binary stream of your local docx asset
            with open(input_path, "rb") as file_stream:
                input_bytes = file_stream.read()
                
            # Create the asset upload reference directly via the primary service client
            source_asset = pdf_services.upload(input_stream=input_bytes, mime_type=PDFServicesMediaType.DOCX)
            print("Asset successfully uploaded to Adobe Cloud. Preparing CreatePDFJob...")
            
            # Instantiate the execution task
            create_pdf_job = CreatePDFJob(input_asset=source_asset)
            
            # Submit the job to the remote workflow execution runner
            location = pdf_services.submit(create_pdf_job)
            print(f"Job submitted successfully. Location URI received. Polling remote result...")
            
            # Fetch output responses matching the explicit result type matching the specification
            pdf_services_response = pdf_services.get_job_result(location, CreatePDFResult)
            
            # Download output stream asset
            result_asset = pdf_services_response.get_result().get_asset()
            stream_asset = pdf_services.get_content(result_asset)
            
            # Write final byte values locally to disk memory space
            with open(output_path, "wb") as output_file:
                output_file.write(stream_asset.get_input_stream())
                
            print("Conversion successful. Local PDF written.")

            # 4. Upload result back to S3 'converted/' space
            output_key = key.replace("uploads/", "converted/").replace(".docx", ".pdf").replace(".xlsx", ".pdf")
            s3.upload_file(output_path, bucket, output_key)
            print(f"Uploaded finalized PDF destination file: {output_key}")

            # 5. DIRECT DYNAMODB METADATA SYNCHRONIZATION
            # This updates the data instantly using the exact key format expected by the frontend
            try:
                table = dynamodb.Table("DocumentMetadata")
                
                # Generate a secure, long-lasting download URL for the interface link
                download_presigned_url = s3.generate_presigned_url(
                    "get_object",
                    Params={"Bucket": bucket, "Key": output_key},
                    ExpiresIn=3600  # Link active for 1 hour
                )
                
                print(f"Writing completion state into DocumentMetadata for key: {output_key}")
                table.put_item(
                    Item={
                        "file_name": output_key,
                        "pdf_url": download_presigned_url,
                        "status": "completed"
                    }
                )
                print("Successfully recorded production URL metrics directly to the data layer.")
            except Exception as db_err:
                print(f"Non-blocking database sync warning: {str(db_err)}")

        except Exception as adobe_err:
            print(f"Adobe Engine Core Failure: {str(adobe_err)}")
            raise adobe_err
            
        finally:
            # Cleanup local temporary scratch space disk storage
            for path in [input_path, output_path]:
                if os.path.exists(path):
                    os.remove(path)

    return {
        "statusCode": 200,
        "body": json.dumps("Document converter pipeline executed successfully.")
    }
